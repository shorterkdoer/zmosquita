    /**
     * Agrega las rutas al archivo de rutas
     */
    private function addRoutes(): void
    {
        $routesContent = file_get_contents(ROUTES_FILE);

        // Verificar si las rutas ya existen
        $marker = "// Rutas para {$this->modelName}";
        if (str_contains($routesContent, $marker)) {
            echo COLOR_YELLOW . "  ⚠ " . COLOR_RESET . "Las rutas ya existen en config/routes.php (omitido)\n";
            return;
        }

        $routesToAdd = $marker . "\n\n";
        $routesToAdd .= "Router::get('/{$this->entityName}', [{$this->controllerName}::class, 'index'], [AdminMiddleware::class]);\n";
        $routesToAdd .= "Router::get('/{$this->entityName}/edit/{id}', [{$this->controllerName}::class, 'edit'], [AdminMiddleware::class]);\n";
        $routesToAdd .= "Router::get('/{$this->entityName}/create', [{$this->controllerName}::class, 'create'], [AdminMiddleware::class]);\n";
        $routesToAdd .= "Router::post('/{$this->entityName}/store', [{$this->controllerName}::class, 'store'], [AdminMiddleware::class]);\n";
        $routesToAdd .= "Router::post('/{$this->entityName}/update/{id}', [{$this->controllerName}::class, 'update'], [AdminMiddleware::class]);\n";
        $routesToAdd .= "Router::get('/{$this->entityName}/vista/{id}', [{$this->controllerName}::class, 'vista'], [AdminMiddleware::class]);\n";
        $routesToAdd .= "Router::post('/{$this->entityName}/delete/{id}', [{$this->controllerName}::class, 'delete'], [AdminMiddleware::class]);\n\n";

        // Buscar un lugar apropiado para insertar
        // 1. Buscar "// Rutas para Ciudades" como referencia
        if (preg_match('/(\n\/\/ Rutas para Ciudades\n)/', $routesContent, $matches)) {
            $routesContent = str_replace(
                $matches[1],
                $routesToAdd . $matches[1],
                $routesContent
            );
        }
        // 2. Si no, buscar "// Rutas para Provincia" como referencia
        elseif (preg_match('/(\n\/\/ Rutas para Provincia\n)/', $routesContent, $matches)) {
            $routesContent = str_replace(
                $matches[1],
                $routesToAdd . $matches[1],
                $routesContent
            );
        }
        // 3. Si no, buscar "// Rutas para" genérico y agregar antes
        elseif (preg_match('/\n\/\/ Rutas para /', $routesContent)) {
            $routesContent = preg_replace(
                '/(\n\/\/ Rutas para )/',
                "\n" . trim($routesToAdd) . "\n$1",
                $routesContent,
                1
            );
        }
        // 4. Si no, agregar al final del archivo
        else {
            $routesContent = trim($routesContent) . "\n\n" . $routesToAdd;
        }

        file_put_contents(ROUTES_FILE, $routesContent);

        echo COLOR_GREEN . "  ✓ " . COLOR_RESET . "Rutas agregadas a config/routes.php\n";
    }

    /**
     * Escribe un archivo
     */
    private function writeFile(string $path, string $content, string $type): void
    {
        $dir = dirname($path);
        if (!is_dir($dir)) {
            mkdir($dir, 0755, true);
        }

        file_put_contents($path, $content);
        echo COLOR_GREEN . "  ✓ " . COLOR_RESET . "{$type} creado: " . COLOR_CYAN . $path . COLOR_RESET . "\n";
    }

