    /**
     * Crea las configuraciones de CRUD
     */
    private function createCrudConfigs(): void
    {
        $configDir = CRUDS_DIR . "/{$this->entityName}";

        if (!is_dir($configDir)) {
            mkdir($configDir, 0755, true);
        }

        // Generar campos para configuración
        $camposConfig = $this->generateCamposConfig();

        // Crear config index
        $this->createIndexConfig($configDir, $camposConfig);
        $this->createCreateConfig($configDir, $camposConfig);
        $this->createEditConfig($configDir, $camposConfig);
        $this->createDeleteConfig($configDir, $camposConfig);
    }

    /**
     * Genera la configuración de campos
     */
    private function generateCamposConfig(): string
    {
        $config = "";

        foreach ($this->columns as $col) {
            // Verificar si es foreign key para usar select
            $isForeignKey = isset($this->foreignKeys[$col['name']]);
            $fieldType = $isForeignKey ? 'select' : $this->mapSqlToInputType($col['type']);
            $required = !$col['nullable'] && !$col['auto_increment'] ? 'true' : 'false';
            $hidden = $col['name'] === $this->primaryKey ? 'true' : 'false';
            $readonly = $col['auto_increment'] ? 'true' : 'false';
            $label = ucfirst($col['name']);
            $maxlength = $col['length'] ? $col['length'] : '255';

            $config .= "                '{$col['name']}' => [\n";
            $config .= "                    'nombre' => '{$col['name']}',\n";
            $config .= "                    'type' => '{$fieldType}',\n";
            $config .= "                    'label' => '{$label}',\n";
            $config .= "                    'maxlength' => {$maxlength},\n";
            $config .= "                    'readonly' => {$readonly},\n";
            $config .= "                    'hidden' => {$hidden},\n";
            $config .= "                    'required' => {$required},\n";
            $config .= "                    'placeholder' => 'Ingrese {$label}',\n";
            $config .= "                    'help' => 'Ingrese {$label}',\n";
            $config .= "                    'class' => 'form-control',\n";
            $config .= "                    'style' => 'width: 100%;',\n";
            $config .= "                    'autocomplete' => 'off',\n";

            // Para foreign keys, añadir opciones
            if ($isForeignKey) {
                $relatedTable = $this->foreignKeys[$col['name']];
                $config .= "                    'tabla_rel' => '{$relatedTable}',\n";
                $config .= "                    'options' => [],\n";
            }

            $config .= "                ],\n";
        }

        return $config;
    }

    /**
     * Mapea tipos SQL a tipos de input
     */
    private function mapSqlToInputType(string $sqlType): string
    {
        return match (true) {
            str_contains($sqlType, 'text') => 'textarea',
            str_contains($sqlType, 'int') => 'number',
            str_contains($sqlType, 'decimal') || str_contains($sqlType, 'float') || str_contains($sqlType, 'double') => 'number',
            str_contains($sqlType, 'date') => 'date',
            str_contains($sqlType, 'email') => 'email',
            default => 'text',
        };
    }

