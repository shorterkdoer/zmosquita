        "npm-asset/lightgallery": "^2.8",
        "vlucas/phpdotenv": "^5.6",
        "gregwar/captcha": "^1.2",
        "sonata-project/google-authenticator": "^2.3",
        "setasign/fpdi-tcpdf": "^2.3",
